{
  "name": "scruffy",
  "version": "0.0.0",
  "private": true,
  "description": "Service-controlled three-gate review system for organization repositories",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "harness": "tsx test/harness/e2e.ts",
    "corpus": "tsx src/corpus/run.ts",
    "corpus:nightly": "tsx src/corpus/nightly-run.ts",
    "corpus:release": "tsx src/corpus/release-run.ts",
    "corpus:grounded": "tsx src/corpus/grounded-run.ts",
    "corpus:all": "tsx src/corpus/all-run.ts",
    "llm-smoke": "tsx scripts/llm-smoke.ts",
    "db:up": "docker compose up -d db && node scripts/wait-for-db.mjs",
    "db:down": "docker compose down -v",
    "db:migrate": "tsx src/persistence/migrate.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@octokit/webhooks-methods": "^5.1.1",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
