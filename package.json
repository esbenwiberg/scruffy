{
  "name": "scruffy",
  "version": "0.0.0",
  "private": true,
  "description": "Service-controlled three-gate review system for organization repositories",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "harness": "tsx test/harness/e2e.ts",
    "corpus": "tsx src/corpus/run.ts",
    "corpus:nightly": "tsx src/corpus/nightly-run.ts",
    "corpus:release": "tsx src/corpus/release-run.ts",
    "corpus:grounded": "tsx src/corpus/grounded-run.ts",
    "corpus:all": "tsx src/corpus/all-run.ts",
    "corpus:grounded:live": "tsx scripts/grounded-live.ts",
    "scruffy:review": "tsx scripts/review-pr.ts",
    "llm-smoke": "tsx scripts/llm-smoke.ts",
    "db:up": "docker compose up -d db && node scripts/wait-for-db.mjs",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v",
    "db:migrate": "tsx src/persistence/migrate.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/request": "^10.0.11",
    "@octokit/webhooks-methods": "^5.1.1",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^17.7.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.0",
    "vitest": "^3.2.7"
  }
}
